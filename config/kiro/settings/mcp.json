{
  "mcpServers": {},
  "powers": {
    "mcpServers": {
      "power-figma-figma": {
        "type": "http",
        "url": "https://mcp.figma.com/mcp"
      },
      "power-miro-codegen-miro-mcp": {
        "url": "https://mcp.miro.com/",
        "disabled": false,
        "headers": {
          "X-AI-Source": "kiro-code-gen-extension"
        }
      },
      "power-amazon-aurora-postgresql-awslabs.postgres-mcp-server": {
        "args": [
          "awslabs.postgres-mcp-server@latest"
        ],
        "command": "uvx"
      },
      "power-aws-devops-agent-aws-mcp": {
        "command": "uvx",
        "timeout": 100000,
        "transport": "stdio",
        "args": [
          "mcp-proxy-for-aws@latest",
          "https://aws-mcp.us-east-1.api.aws/mcp",
          "--metadata",
          "AWS_REGION=us-east-1"
        ]
      },
      "power-aws-agentcore-agentcore-mcp-server": {
        "command": "uvx",
        "args": [
          "awslabs.amazon-bedrock-agentcore-mcp-server@latest"
        ],
        "disabled": false
      }
    }
  }
}